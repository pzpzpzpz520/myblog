#!/bin/sh

set -e

BASE_DIR=$(cd "$(dirname "$0")"; pwd)
WRAPPER_JAR="$BASE_DIR/.mvn/wrapper/maven-wrapper.jar"
JAVA_CMD="${JAVA_HOME:+$JAVA_HOME/bin/}java"

if [ ! -f "$WRAPPER_JAR" ]; then
  echo "Missing Maven Wrapper jar: $WRAPPER_JAR" >&2
  echo "Please ensure .mvn/wrapper/maven-wrapper.jar is present." >&2
  exit 1
fi

exec "$JAVA_CMD" -Dmaven.multiModuleProjectDirectory="$BASE_DIR" -cp "$WRAPPER_JAR" org.apache.maven.wrapper.MavenWrapperMain "$@"
