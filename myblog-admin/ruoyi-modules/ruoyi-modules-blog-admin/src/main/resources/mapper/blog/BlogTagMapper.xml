<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.blogadmin.mapper.BlogTagMapper">

    <resultMap id="BlogTagResult" type="BlogTag">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="articleCount" column="article_count"/>
    </resultMap>

    <select id="selectTagList" parameterType="BlogTagQuery" resultMap="BlogTagResult">
        select t.id,
               t.name,
               count(at.article_id) as article_count
        from tag t
                 left join article_tag at on at.tag_id = t.id
        <where>
            <if test="name != null and name != ''">
                and t.name like concat('%', #{name}, '%')
            </if>
        </where>
        group by t.id, t.name
        order by t.id asc
    </select>

    <select id="selectTagById" parameterType="Long" resultMap="BlogTagResult">
        select t.id,
               t.name,
               count(at.article_id) as article_count
        from tag t
                 left join article_tag at on at.tag_id = t.id
        where t.id = #{tagId}
        group by t.id, t.name
    </select>

    <select id="checkTagNameUnique" resultType="BlogTag">
        select id, name
        from tag
        where name = #{name}
        <if test="excludeId != null">
            and id != #{excludeId}
        </if>
        limit 1
    </select>

    <insert id="insertTag" parameterType="BlogTag" useGeneratedKeys="true" keyProperty="id">
        insert into tag (name)
        values (#{name})
    </insert>

    <update id="updateTag" parameterType="BlogTag">
        update tag
        set name = #{name}
        where id = #{id}
    </update>

    <delete id="deleteTagById" parameterType="Long">
        delete
        from tag
        where id = #{tagId}
    </delete>

    <select id="countArticleByTagId" parameterType="Long" resultType="Integer">
        select count(1)
        from article_tag
        where tag_id = #{tagId}
    </select>

</mapper>
